<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F2F6FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="#0F766E" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Cert Installer"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#102A43" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Chọn chứng chỉ từ file hoặc tải từ Burp Suite, theo dõi tiến trình ngay trong log hoạt động bên dưới."
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:textColor="#52606D" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:elevation="2dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thao tác nhanh"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#102A43" />

            <Button
                android:id="@+id/btnPick"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Chọn chứng chỉ từ file" />

            <Button
                android:id="@+id/btnDownloadFromUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Tải cert từ Burp Suite" />

            <Button
                android:id="@+id/btnSaved"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Quản lý chứng chỉ đã lưu" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:elevation="2dp"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạng thái"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#102A43" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Chưa chọn file"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:textColor="#334E68" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#0F766E" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_panel"
            android:elevation="2dp"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tự động reboot sau khi cài đặt"
                android:textSize="14sp"
                android:textColor="#102A43" />

            <Switch
                android:id="@+id/switchAutoReboot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCheckCerts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kiểm tra Cert"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnReboot"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reboot"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:elevation="2dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nhật ký hoạt động"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#102A43" />

                <Button
                    android:id="@+id/btnClearLog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xoá log" />

                <Button
                    android:id="@+id/btnCopyLog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Copy" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:fillViewport="true"
                android:nestedScrollingEnabled="true"
                android:scrollbars="vertical"
                android:background="#F8FAFC"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Log sẽ xuất hiện ở đây..."
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:textColor="#243B53"
                    android:lineSpacingExtra="3dp"
                    android:padding="4dp"
                    android:longClickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:textIsSelectable="true" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
